---
import IdocHeader from '@idocs/components/IdocHeader.astro';
import PayloadModal from '@idocs/components/PayloadModal.astro';
import SegmentCard from '@idocs/components/SegmentCard.astro';
import { SERVICES_DATA } from '@idocs/data/services';
/**
 * Página SRVMAS - Mestre de Serviços
 */
import IdocLayout from '@idocs/layouts/IdocLayout.astro';
import { flattenTree } from '@idocs/utils/tree';

const { title, description, tree, segments } = SERVICES_DATA;
const flatSegments = flattenTree(tree);
---

<IdocLayout title={title} description={description} tree={tree} segments={segments}>
  <IdocHeader
    idocType="SRVMAS"
    title="Mestre de Serviços"
    description={description}
  />
  
  <section class="segments-list">
    {flatSegments.map(({ segment, max }) => {
      const def = segments[segment];
      if (!def) return null;
      
      return (
        <SegmentCard 
          name={segment} 
          segment={def} 
          maxOccurs={max} 
        />
      );
    })}
  </section>
  
  <PayloadModal />
</IdocLayout>

<style>
  .segments-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>

<script>
  // CSV Export
  document.querySelectorAll('.btn-csv').forEach(btn => {
    btn.addEventListener('click', () => {
      const segmentName = btn.getAttribute('data-segment');
      if (!segmentName) return;
      
      const card = document.getElementById(segmentName);
      if (!card) return;
      
      const rows = card.querySelectorAll('.fields-table tbody tr');
      const csv = Array.from(rows).map(row => {
        const cells = row.querySelectorAll('td');
        return [
          cells[0]?.textContent?.trim() || '',
          `"${cells[1]?.textContent?.trim() || ''}"`,
          cells[2]?.textContent?.trim() || ''
        ].join(',');
      }).join('\n');
      
      navigator.clipboard.writeText(`Campo,Descrição,Tipo\n${csv}`);
      
      const original = btn.textContent;
      btn.textContent = '✓ Copiado!';
      setTimeout(() => btn.textContent = original, 2000);
    });
  });
  
  // Payload Modal
  document.querySelectorAll('.btn-payload').forEach(btn => {
    btn.addEventListener('click', () => {
      const segmentName = btn.getAttribute('data-segment');
      if (!segmentName) return;
      
      const card = document.getElementById(segmentName);
      if (!card) return;
      
      const rows = card.querySelectorAll('.fields-table tbody tr');
      const payload: Record<string, string> = {};
      
      rows.forEach(row => {
        const cells = row.querySelectorAll('td');
        const fieldName = cells[0]?.textContent?.trim() || '';
        if (fieldName) {
          payload[fieldName] = '';
        }
      });
      
      if (typeof window.showPayloadModal === 'function') {
        window.showPayloadModal(segmentName, { [segmentName]: payload });
      }
    });
  });
</script>
