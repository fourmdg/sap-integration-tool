---

<BaseLayout title="Biblioteca de Templates" description="Payloads JSON prontos para integração SAP">
  <div class="templates-page">
    <header class="page-header">
      <h1 class="page-title">📋 Biblioteca de Templates</h1>
      <p class="page-subtitle">
        Copie modelos JSON prontos e validados para acelerar sua integração.
      </p>
    </header>

    <nav class="category-nav" aria-label="Categorias">
      {templates.map(cat => (
        <a href={`#${cat.category.toLowerCase()}`} class="category-link">
          <span class="category-link-icon">{cat.icon}</span>
          {cat.category}
        </a>
      ))}
    </nav>

    {templates.map(category => (
      <section id={category.category.toLowerCase()} class="category-section">
        <h2 class="category-title">
          <span class="category-icon">{category.icon}</span>
          {category.category}
        </h2>

        <div class="templates-grid">
          {category.items.map(template => (
            <article class="template-card" id={template.id}>
              <header class="template-header">
                <h3 class="template-title">{template.title}</h3>
                <span class="template-badge" style={`background: ${template.badgeColor}`}>
                  {template.badge}
                </span>
              </header>

              <p class="template-description">{template.description}</p>

              <div class="template-payload">
                <div class="payload-header">
                  <span class="payload-label">JSON Payload</span>
                  <button
                    class="copy-btn"
                    data-payload={template.payload}
                    aria-label="Copiar payload"
                  >
                    📋 Copiar
                  </button>
                </div>
                <pre class="payload-code"><code>{template.payload}</code></pre>
              </div>

              {template.tips && template.tips.length > 0 && (
                <div class="template-tips">
                  {template.tips.map(tip => (
                    <div class={`tip tip-${tip.type}`}>
                      <span class="tip-icon">
                        {tip.type === 'info' && '💡'}
                        {tip.type === 'warning' && '⚠️'}
                        {tip.type === 'error' && '❌'}
                      </span>
                      <span class="tip-text">{tip.text}</span>
                    </div>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .templates-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-xl);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--heading-color);
    margin: 0 0 var(--spacing-sm);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* Category Navigation */
  .category-nav {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-2xl);
    padding: var(--spacing-md);
    background: var(--card-bg);
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }

  .category-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 10px 20px;
    background: var(--meta-bg);
    color: var(--text-main);
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .category-link:hover {
    background: var(--brand-blue);
    color: white;
  }

  .category-link-icon {
    font-size: 1.1rem;
  }

  /* Category Sections */
  .category-section {
    margin-bottom: var(--spacing-2xl);
    scroll-margin-top: 80px;
  }

  .category-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--heading-color);
    margin: 0 0 var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--border-color);
  }

  .category-icon {
    font-size: 1.5rem;
  }

  /* Templates Grid */
  .templates-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  /* Template Card */
  .template-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: var(--spacing-lg);
    transition: border-color 0.2s;
  }

  .template-card:hover {
    border-color: var(--brand-blue);
  }

  .template-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .template-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--heading-color);
    margin: 0;
  }

  .template-badge {
    font-size: 0.7rem;
    padding: 4px 10px;
    color: white;
    border-radius: 4px;
    font-weight: 700;
    font-family: 'Consolas', 'Monaco', monospace;
    letter-spacing: 0.5px;
  }

  .template-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0 0 var(--spacing-md);
    line-height: 1.5;
  }

  /* Payload Section */
  .template-payload {
    background: var(--sidebar-bg);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: var(--spacing-md);
  }

  .payload-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) var(--spacing-md);
    background: rgba(0, 0, 0, 0.2);
  }

  .payload-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .copy-btn {
    background: var(--brand-blue);
    color: white;
    border: none;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
  }

  .payload-code {
    margin: 0;
    padding: var(--spacing-md);
    overflow-x: auto;
    font-family: 'Consolas', 'Monaco', 'Fira Code', monospace;
    font-size: 0.8rem;
    line-height: 1.5;
    color: #e2e8f0;
    max-height: 300px;
    overflow-y: auto;
  }

  .payload-code code {
    white-space: pre;
  }

  /* Tips */
  .template-tips {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .tip {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 8px;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .tip-info {
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.3);
    color: var(--text-main);
  }

  .tip-warning {
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: var(--text-main);
  }

  .tip-error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: var(--text-main);
  }

  .tip-icon {
    flex-shrink: 0;
  }

  .tip-text {
    flex: 1;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .templates-page {
      padding: var(--spacing-md);
    }

    .page-title {
      font-size: 1.5rem;
    }

    .template-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .payload-code {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  // Copy functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const payload = btn.getAttribute('data-payload');
      if (payload) {
        try {
          await navigator.clipboard.writeText(payload);
          const originalText = btn.textContent;
          btn.textContent = '✅ Copiado!';
          setTimeout(() => {
            btn.textContent = originalText;
          }, 2000);
        } catch (e) {
          console.error('Failed to copy:', e);
        }
      }
    });
  });
</script>
