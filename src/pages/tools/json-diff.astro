---
import DiffJsonViewer from '@features/tools/components/DiffJsonViewer.astro';
/**
 * JSON Diff - Comparador Visual de JSONs
 * Compara JSON de referência com JSON de comparação e identifica diferenças
 */
import ToolLayout from '@features/tools/layouts/ToolLayout.astro';
---

<ToolLayout 
  title="JSON Diff" 
  description="Compare JSONs e identifique diferenças de estrutura, tipos e valores"
  icon="⚖️"
>
  <div class="jd-container">
    <!-- Input Section -->
    <div class="jd-input-section" id="inputSection">
      <div class="jd-input-grid">
        <!-- JSON Referência -->
        <div class="jd-input-panel">
          <div class="jd-input-header">
            <label class="jd-field-label" for="jsonRef">JSON Referência</label>
            <div class="jd-actions">
              <button class="jd-btn-action" id="sampleRefBtn" title="Carregar exemplo">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
                Exemplo
              </button>
              <button class="jd-btn-action" id="clearRefBtn" title="Limpar">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
                Limpar
              </button>
              <button class="jd-btn-action" id="pasteRefBtn" title="Colar do clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                Colar
              </button>
            </div>
          </div>
          <textarea 
            id="jsonRef" 
            class="jd-textarea" 
            placeholder='Cole o JSON de referência aqui...

Este é o JSON "correto" que será usado como base para comparação.'
            spellcheck="false"
          ></textarea>
        </div>
        
        <!-- JSON Comparação -->
        <div class="jd-input-panel">
          <div class="jd-input-header">
            <label class="jd-field-label" for="jsonComp">JSON Comparação</label>
            <div class="jd-actions">
              <button class="jd-btn-action" id="sampleCompBtn" title="Carregar exemplo">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
                Exemplo
              </button>
              <button class="jd-btn-action" id="clearCompBtn" title="Limpar">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
                Limpar
              </button>
              <button class="jd-btn-action" id="pasteCompBtn" title="Colar do clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                Colar
              </button>
            </div>
          </div>
          <textarea 
            id="jsonComp" 
            class="jd-textarea" 
            placeholder='Cole o JSON para comparar aqui...

Este JSON será comparado com a referência para identificar diferenças.'
            spellcheck="false"
          ></textarea>
        </div>
      </div>

      <!-- Swap Button -->
      <div class="jd-swap-container">
        <button class="jd-swap-btn" id="swapBtn" title="Inverter JSONs">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 7H3m0 0l4-4M3 7l4 4M16 17h5m0 0l-4 4m4-4l-4-4"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Resize Handle -->
    <div class="jd-resize-handle" id="resizeHandle">
      <div class="jd-resize-grip">
        <span></span><span></span><span></span>
      </div>
    </div>

    <!-- Error Box -->
    <div class="jd-error" id="errorBox"></div>

    <!-- Results Section -->
    <div class="jd-results" id="resultsSection">
      <!-- Options Bar (moved here) -->
      <div class="jd-options-bar">
        <span class="jd-options-label">Opções:</span>
        <div class="jd-options">
          <label class="jd-toggle">
            <input type="checkbox" id="optIgnoreArrayOrder" />
            <span class="jd-toggle-slider"></span>
            <span class="jd-toggle-label">Ignorar ordem de arrays</span>
          </label>
        </div>
        <div class="jd-view-selector">
          <button class="jd-view-btn jd-view-btn-active" data-view="side-by-side">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="18" rx="1"></rect>
              <rect x="14" y="3" width="7" height="18" rx="1"></rect>
            </svg>
            <span>Lado a Lado</span>
          </button>
          <button class="jd-view-btn" data-view="unified">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="8" y1="13" x2="16" y2="13"></line>
              <line x1="8" y1="17" x2="16" y2="17"></line>
            </svg>
            <span>Técnico</span>
          </button>
          <button class="jd-view-btn" data-view="report">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 20h9"></path>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
            </svg>
            <span>Humano</span>
          </button>
        </div>
      </div>

      <!-- View: Side-by-Side -->
      <div class="jd-view jd-view-active" id="viewSideBySide">
        <div class="jd-sbs-toolbar">
          <div class="jd-stats">
            <button class="jd-stat jd-stat-extra jd-stat-active" data-filter="extra" title="Clique para filtrar">
              <span class="jd-stat-icon">+</span>
              <strong id="statExtra">0</strong>
              <span class="jd-stat-label">propriedades extras</span>
            </button>
            <button class="jd-stat jd-stat-missing jd-stat-active" data-filter="missing" title="Clique para filtrar">
              <span class="jd-stat-icon">−</span>
              <strong id="statMissing">0</strong>
              <span class="jd-stat-label">propriedades faltantes</span>
            </button>
            <button class="jd-stat jd-stat-type jd-stat-active" data-filter="type-wrong" title="Clique para filtrar">
              <span class="jd-stat-icon">⚡</span>
              <strong id="statType">0</strong>
              <span class="jd-stat-label">tipos diferentes</span>
            </button>
            <button class="jd-stat jd-stat-value jd-stat-active" data-filter="value-diff" title="Clique para filtrar">
              <span class="jd-stat-icon">≠</span>
              <strong id="statValue">0</strong>
              <span class="jd-stat-label">valores diferentes</span>
            </button>
          </div>
          <button class="jd-btn-action" id="fullscreenBtn" title="Tela cheia">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
            </svg>
            Expandir
          </button>
        </div>
        <div class="jd-side-by-side" id="sideBySideContainer">
          <DiffJsonViewer id="diffRef" label="Referência" height="450px" side="left" />
          <DiffJsonViewer id="diffComp" label="Comparação" height="450px" side="right" />
        </div>
      </div>

      <!-- View: Unified (Relatório Técnico) -->
      <div class="jd-view" id="viewUnified">
        <div class="jd-unified-container">
          <div class="jd-unified-header">
            <span class="jd-unified-label">Relatório Técnico</span>
            <button class="jd-btn-action" id="copyUnifiedBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              Copiar
            </button>
          </div>
          <div class="jd-unified-content" id="unifiedContent"></div>
        </div>
      </div>

      <!-- View: Report (Relatório Humano) -->
      <div class="jd-view" id="viewReport">
        <div class="jd-report-container">
          <div class="jd-report-header">
            <span class="jd-report-label">Relatório Humano</span>
            <div class="jd-report-actions">
              <button class="jd-btn-action" id="copyJsonBtn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                JSON
              </button>
              <button class="jd-btn-action" id="copyMarkdownBtn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16v16H4z"></path>
                  <path d="M7 15V9l2 2 2-2v6M17 9v6l-2-2-2 2"></path>
                </svg>
                Markdown
              </button>
            </div>
          </div>
          <div class="jd-report-content" id="reportContent"></div>
        </div>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  // ========== TYPES ==========
  type DiffType = 'extra' | 'missing' | 'type-wrong' | 'value-diff' | 'unchanged';

  interface DiffItem {
    path: string;
    type: DiffType;
    refValue?: any;
    compValue?: any;
    refType?: string;
    compType?: string;
  }

  interface DiffOptions {
    ignoreArrayOrder: boolean;
  }

  interface DiffResult {
    items: DiffItem[];
    stats: {
      extra: number;
      missing: number;
      typeWrong: number;
      valueDiff: number;
      unchanged: number;
    };
  }

  // ========== DIFF ENGINE ==========
  function getType(value: any): string {
    if (value === null) return 'null';
    if (value === undefined) return 'undefined';
    if (Array.isArray(value)) return 'array';
    return typeof value;
  }

  function normalizeArray(arr: any[], options: DiffOptions): any[] {
    if (!options.ignoreArrayOrder) return arr;
    try {
      return [...arr].sort((a, b) => JSON.stringify(a).localeCompare(JSON.stringify(b)));
    } catch {
      return arr;
    }
  }

  function diffRecursive(
    ref: any,
    comp: any,
    path: string,
    options: DiffOptions,
    items: DiffItem[]
  ): void {
    const refType = getType(ref);
    const compType = getType(comp);

    if (ref === comp) {
      return;
    }

    // Tipos diferentes
    if (refType !== compType) {
      items.push({ path, type: 'type-wrong', refValue: ref, compValue: comp, refType, compType });
      return;
    }

    // Arrays
    if (refType === 'array') {
      const refArr = normalizeArray(ref as any[], options);
      const compArr = normalizeArray(comp as any[], options);
      const maxLen = Math.max(refArr.length, compArr.length);

      for (let i = 0; i < maxLen; i++) {
        const itemPath = `${path}[${i}]`;
        if (i >= refArr.length) {
          // Extra no comparação
          items.push({ path: itemPath, type: 'extra', compValue: compArr[i] });
        } else if (i >= compArr.length) {
          // Faltando no comparação
          items.push({ path: itemPath, type: 'missing', refValue: refArr[i] });
        } else {
          diffRecursive(refArr[i], compArr[i], itemPath, options, items);
        }
      }
      return;
    }

    // Objetos
    if (refType === 'object') {
      const refKeys = new Set(Object.keys(ref || {}));
      const compKeys = new Set(Object.keys(comp || {}));
      const allKeys = new Set([...refKeys, ...compKeys]);

      for (const key of allKeys) {
        const keyPath = path ? `${path}.${key}` : key;
        if (!refKeys.has(key)) {
          // Extra no comparação
          items.push({ path: keyPath, type: 'extra', compValue: comp[key] });
        } else if (!compKeys.has(key)) {
          // Faltando no comparação
          items.push({ path: keyPath, type: 'missing', refValue: ref[key] });
        } else {
          diffRecursive(ref[key], comp[key], keyPath, options, items);
        }
      }
      return;
    }

    // Primitivos com valores diferentes
    if (ref !== comp) {
      items.push({ path, type: 'value-diff', refValue: ref, compValue: comp });
    }
  }

  function deepDiff(ref: any, comp: any, options: DiffOptions): DiffResult {
    const items: DiffItem[] = [];
    diffRecursive(ref, comp, '$', options, items);

    return {
      items,
      stats: {
        extra: items.filter(i => i.type === 'extra').length,
        missing: items.filter(i => i.type === 'missing').length,
        typeWrong: items.filter(i => i.type === 'type-wrong').length,
        valueDiff: items.filter(i => i.type === 'value-diff').length,
        unchanged: items.filter(i => i.type === 'unchanged').length,
      },
    };
  }

  // ========== DOM ELEMENTS ==========
  const jsonRef = document.getElementById('jsonRef') as HTMLTextAreaElement;
  const jsonComp = document.getElementById('jsonComp') as HTMLTextAreaElement;
  const swapBtn = document.getElementById('swapBtn') as HTMLButtonElement;
  const sampleRefBtn = document.getElementById('sampleRefBtn') as HTMLButtonElement;
  const sampleCompBtn = document.getElementById('sampleCompBtn') as HTMLButtonElement;
  const clearRefBtn = document.getElementById('clearRefBtn') as HTMLButtonElement;
  const clearCompBtn = document.getElementById('clearCompBtn') as HTMLButtonElement;
  const pasteRefBtn = document.getElementById('pasteRefBtn') as HTMLButtonElement;
  const pasteCompBtn = document.getElementById('pasteCompBtn') as HTMLButtonElement;
  const errorBox = document.getElementById('errorBox') as HTMLDivElement;
  const resultsSection = document.getElementById('resultsSection') as HTMLDivElement;

  // Options
  const optIgnoreArrayOrder = document.getElementById('optIgnoreArrayOrder') as HTMLInputElement;

  // Stats (agora são botões filtros)
  const statExtra = document.getElementById('statExtra') as HTMLElement;
  const statMissing = document.getElementById('statMissing') as HTMLElement;
  const statType = document.getElementById('statType') as HTMLElement;
  const statValue = document.getElementById('statValue') as HTMLElement;
  const filterBtns = document.querySelectorAll('.jd-stat[data-filter]') as NodeListOf<HTMLButtonElement>;
  
  // Filtros ativos (todos começam ativos)
  const activeFilters = new Set(['extra', 'missing', 'type-wrong', 'value-diff']);

  // Views
  const viewBtns = document.querySelectorAll('.jd-view-btn');
  const viewSideBySide = document.getElementById('viewSideBySide') as HTMLDivElement;
  const viewUnified = document.getElementById('viewUnified') as HTMLDivElement;
  const viewReport = document.getElementById('viewReport') as HTMLDivElement;
  const unifiedContent = document.getElementById('unifiedContent') as HTMLDivElement;
  const reportContent = document.getElementById('reportContent') as HTMLDivElement;

  // Diff viewers
  const diffRefLines = document.getElementById('diffRefLines') as HTMLDivElement;
  const diffCompLines = document.getElementById('diffCompLines') as HTMLDivElement;
  const diffRefScroll = document.querySelector('[data-djv-scroll="diffRef"]') as HTMLDivElement;
  const diffCompScroll = document.querySelector('[data-djv-scroll="diffComp"]') as HTMLDivElement;

  // Export buttons
  const copyUnifiedBtn = document.getElementById('copyUnifiedBtn') as HTMLButtonElement;
  const copyJsonBtn = document.getElementById('copyJsonBtn') as HTMLButtonElement;
  const copyMarkdownBtn = document.getElementById('copyMarkdownBtn') as HTMLButtonElement;

  // ========== STATE ==========
  let currentResult: DiffResult | null = null;
  let refParsed: any = null;
  let compParsed: any = null;
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;

  // ========== HELPERS ==========
  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function formatValue(value: any, maxLen = 60): string {
    if (value === undefined) return 'undefined';
    if (value === null) return 'null';
    const str = JSON.stringify(value);
    return str.length > maxLen ? str.substring(0, maxLen - 3) + '...' : str;
  }

  function showError(msg: string) {
    errorBox.textContent = `❌ ${msg}`;
    errorBox.classList.add('show');
    resultsSection.classList.remove('show');
  }

  function hideError() {
    errorBox.classList.remove('show');
  }

  function getOptions(): DiffOptions {
    return {
      ignoreArrayOrder: optIgnoreArrayOrder.checked,
    };
  }

  function saveOptions() {
    localStorage.setItem('jd-options', JSON.stringify(getOptions()));
  }

  function loadOptions() {
    try {
      const saved = localStorage.getItem('jd-options');
      if (saved) {
        const opts = JSON.parse(saved);
        optIgnoreArrayOrder.checked = opts.ignoreArrayOrder ?? false;
      }
    } catch {}
  }

  // ========== JSON RENDERING ==========
  function syntaxHighlight(json: string): string {
    return json
      .replace(/"([^"]+)":/g, '<span class="djv-key">"$1"</span><span class="djv-colon">:</span>')
      .replace(/: "([^"]*)"/g, ': <span class="djv-string">"$1"</span>')
      .replace(/: (\d+\.?\d*)/g, ': <span class="djv-number">$1</span>')
      .replace(/: (true|false)/g, ': <span class="djv-boolean">$1</span>')
      .replace(/: (null)/g, ': <span class="djv-null">$1</span>')
      .replace(/([{}\[\]])/g, '<span class="djv-bracket">$1</span>')
      .replace(/,$/gm, '<span class="djv-comma">,</span>');
  }

  function renderJsonWithDiff(
    json: any,
    diffItems: DiffItem[],
    side: 'ref' | 'comp'
  ): string {
    const formatted = JSON.stringify(json, null, 2);
    const lines = formatted.split('\n');
    
    const diffMap = new Map<string, DiffType>();
    for (const item of diffItems) {
      diffMap.set(item.path, item.type);
    }

    let html = '';
    let lineNum = 0;

    for (const line of lines) {
      lineNum++;
      const highlighted = syntaxHighlight(escapeHtml(line));
      
      let diffClass = '';
      let indicator = ' ';
      
      const keyMatch = line.match(/^\s*"([^"]+)":/);
      if (keyMatch) {
        const key = keyMatch[1];
        for (const [path, type] of diffMap) {
          const pathKey = path.split('.').pop()?.replace(/\[\d+\]$/, '');
          if (pathKey === key) {
            if (type === 'extra' && side === 'comp') {
              diffClass = 'djv-added';
              indicator = '+';
            } else if (type === 'missing' && side === 'ref') {
              diffClass = 'djv-removed';
              indicator = '−';
            } else if (type === 'type-wrong') {
              diffClass = 'djv-type-changed';
              indicator = '⚡';
            } else if (type === 'value-diff') {
              diffClass = 'djv-value-changed';
              indicator = '≠';
            }
            break;
          }
        }
      }

      html += `<div class="djv-line ${diffClass}">`;
      html += `<span class="djv-line-num">${lineNum}</span>`;
      html += `<span class="djv-line-indicator">${indicator}</span>`;
      html += `<span class="djv-line-content">${highlighted}</span>`;
      html += '</div>';
    }

    return html;
  }

  // ========== UNIFIED VIEW ==========
  function renderUnifiedView(diffItems: DiffItem[]): string {
    const filtered = diffItems.filter(i => i.type !== 'unchanged');
    
    if (filtered.length === 0) {
      return '<div class="djv-empty">✅ Os JSONs são idênticos!</div>';
    }

    let html = '';

    for (const item of filtered) {
      let cls = '';
      let icon = '';
      let label = '';
      let content = '';

      switch (item.type) {
        case 'extra':
          cls = 'djv-added';
          icon = '+';
          label = 'EXTRA';
          content = `<span class="djv-key">${escapeHtml(item.path)}</span>: ${escapeHtml(formatValue(item.compValue))}`;
          break;
        case 'missing':
          cls = 'djv-removed';
          icon = '−';
          label = 'FALTANTE';
          content = `<span class="djv-key">${escapeHtml(item.path)}</span>: ${escapeHtml(formatValue(item.refValue))}`;
          break;
        case 'type-wrong':
          cls = 'djv-type-changed';
          icon = '⚡';
          label = 'TIPO';
          content = `<span class="djv-key">${escapeHtml(item.path)}</span>: esperado <span class="djv-boolean">${item.refType}</span>, encontrado <span class="djv-null">${item.compType}</span>`;
          break;
        case 'value-diff':
          cls = 'djv-value-changed';
          icon = '≠';
          label = 'VALOR';
          content = `<span class="djv-key">${escapeHtml(item.path)}</span>: ${escapeHtml(formatValue(item.refValue))} → ${escapeHtml(formatValue(item.compValue))}`;
          break;
      }

      html += `<div class="djv-line ${cls}">`;
      html += `<span class="djv-line-indicator">${icon}</span>`;
      html += `<span class="jd-unified-tag">${label}</span>`;
      html += `<span class="djv-line-content">${content}</span>`;
      html += '</div>';
    }

    return html;
  }

  // ========== REPORT VIEW ==========
  function renderReportView(diffItems: DiffItem[]): string {
    const grouped = {
      extra: diffItems.filter(i => i.type === 'extra'),
      missing: diffItems.filter(i => i.type === 'missing'),
      typeWrong: diffItems.filter(i => i.type === 'type-wrong'),
      valueDiff: diffItems.filter(i => i.type === 'value-diff'),
    };

    if (grouped.extra.length === 0 && grouped.missing.length === 0 && 
        grouped.typeWrong.length === 0 && grouped.valueDiff.length === 0) {
      return '<div class="jd-report-empty">✅ Os JSONs são idênticos!</div>';
    }

    let html = '';

    if (grouped.extra.length > 0) {
      html += `<div class="jd-report-section jd-report-extra">`;
      html += `<div class="jd-report-section-header">+ Propriedades Extras (${grouped.extra.length})</div>`;
      html += `<div class="jd-report-section-desc">Propriedades que existem no JSON de comparação mas não na referência</div>`;
      html += `<div class="jd-report-section-content">`;
      for (const item of grouped.extra) {
        html += `<div class="jd-report-item">`;
        html += `<code class="jd-report-path">${escapeHtml(item.path)}</code>`;
        html += `<span class="jd-report-value">${escapeHtml(formatValue(item.compValue))}</span>`;
        html += `</div>`;
      }
      html += `</div></div>`;
    }

    if (grouped.missing.length > 0) {
      html += `<div class="jd-report-section jd-report-missing">`;
      html += `<div class="jd-report-section-header">− Propriedades Faltantes (${grouped.missing.length})</div>`;
      html += `<div class="jd-report-section-desc">Propriedades que existem na referência mas faltam no JSON de comparação</div>`;
      html += `<div class="jd-report-section-content">`;
      for (const item of grouped.missing) {
        html += `<div class="jd-report-item">`;
        html += `<code class="jd-report-path">${escapeHtml(item.path)}</code>`;
        html += `<span class="jd-report-value">${escapeHtml(formatValue(item.refValue))}</span>`;
        html += `</div>`;
      }
      html += `</div></div>`;
    }

    if (grouped.typeWrong.length > 0) {
      html += `<div class="jd-report-section jd-report-type">`;
      html += `<div class="jd-report-section-header">⚡ Tipos Incorretos (${grouped.typeWrong.length})</div>`;
      html += `<div class="jd-report-section-desc">Propriedades com tipo de dado diferente do esperado</div>`;
      html += `<div class="jd-report-section-content">`;
      for (const item of grouped.typeWrong) {
        html += `<div class="jd-report-item">`;
        html += `<code class="jd-report-path">${escapeHtml(item.path)}</code>`;
        html += `<span class="jd-report-change">`;
        html += `<span class="jd-report-expected">esperado: <strong>${item.refType}</strong></span>`;
        html += `<span class="jd-report-arrow">→</span>`;
        html += `<span class="jd-report-found">encontrado: <strong>${item.compType}</strong></span>`;
        html += `</span></div>`;
      }
      html += `</div></div>`;
    }

    if (grouped.valueDiff.length > 0) {
      html += `<div class="jd-report-section jd-report-value">`;
      html += `<div class="jd-report-section-header">≠ Valores Diferentes (${grouped.valueDiff.length})</div>`;
      html += `<div class="jd-report-section-desc">Propriedades com valores diferentes do esperado</div>`;
      html += `<div class="jd-report-section-content">`;
      for (const item of grouped.valueDiff) {
        html += `<div class="jd-report-item">`;
        html += `<code class="jd-report-path">${escapeHtml(item.path)}</code>`;
        html += `<span class="jd-report-change">`;
        html += `<span class="jd-report-expected">${escapeHtml(formatValue(item.refValue, 40))}</span>`;
        html += `<span class="jd-report-arrow">→</span>`;
        html += `<span class="jd-report-found">${escapeHtml(formatValue(item.compValue, 40))}</span>`;
        html += `</span></div>`;
      }
      html += `</div></div>`;
    }

    return html;
  }

  // ========== EXPORT ==========
  function diffToMarkdown(result: DiffResult): string {
    const lines: string[] = [];
    lines.push('# Relatório de Diferenças JSON\n');
    lines.push(`## Resumo`);
    lines.push(`- **Propriedades extras:** ${result.stats.extra}`);
    lines.push(`- **Propriedades faltantes:** ${result.stats.missing}`);
    lines.push(`- **Tipos incorretos:** ${result.stats.typeWrong}`);
    lines.push(`- **Valores diferentes:** ${result.stats.valueDiff}`);
    lines.push('');

    const grouped = {
      extra: result.items.filter(i => i.type === 'extra'),
      missing: result.items.filter(i => i.type === 'missing'),
      typeWrong: result.items.filter(i => i.type === 'type-wrong'),
      valueDiff: result.items.filter(i => i.type === 'value-diff'),
    };

    if (grouped.extra.length) {
      lines.push(`## + Propriedades Extras (${grouped.extra.length})`);
      for (const item of grouped.extra) {
        lines.push(`- \`${item.path}\`: ${formatValue(item.compValue)}`);
      }
      lines.push('');
    }

    if (grouped.missing.length) {
      lines.push(`## − Propriedades Faltantes (${grouped.missing.length})`);
      for (const item of grouped.missing) {
        lines.push(`- \`${item.path}\`: ${formatValue(item.refValue)}`);
      }
      lines.push('');
    }

    if (grouped.typeWrong.length) {
      lines.push(`## ⚡ Tipos Incorretos (${grouped.typeWrong.length})`);
      for (const item of grouped.typeWrong) {
        lines.push(`- \`${item.path}\`: esperado \`${item.refType}\`, encontrado \`${item.compType}\``);
      }
      lines.push('');
    }

    if (grouped.valueDiff.length) {
      lines.push(`## ≠ Valores Diferentes (${grouped.valueDiff.length})`);
      for (const item of grouped.valueDiff) {
        lines.push(`- \`${item.path}\`: ${formatValue(item.refValue)} → ${formatValue(item.compValue)}`);
      }
      lines.push('');
    }

    return lines.join('\n');
  }

  // ========== MAIN COMPARE ==========
  function compare() {
    hideError();

    const refText = jsonRef.value.trim();
    const compText = jsonComp.value.trim();

    if (!refText && !compText) {
      resultsSection.classList.remove('show');
      return;
    }

    if (!refText) {
      showError('Cole o JSON de referência');
      return;
    }

    if (!compText) {
      showError('Cole o JSON de comparação');
      return;
    }

    try {
      refParsed = JSON.parse(refText);
    } catch (e: any) {
      showError(`JSON Referência inválido: ${e.message}`);
      return;
    }

    try {
      compParsed = JSON.parse(compText);
    } catch (e: any) {
      showError(`JSON Comparação inválido: ${e.message}`);
      return;
    }

    const options = getOptions();
    currentResult = deepDiff(refParsed, compParsed, options);

    // Update stats
    statExtra.textContent = String(currentResult.stats.extra);
    statMissing.textContent = String(currentResult.stats.missing);
    statType.textContent = String(currentResult.stats.typeWrong);
    statValue.textContent = String(currentResult.stats.valueDiff);

    // Render views
    renderSideBySide();
    renderUnified();
    renderReport();

    resultsSection.classList.add('show');
  }

  function renderSideBySide() {
    if (!currentResult || !refParsed || !compParsed) return;

    // Formatar os JSONs
    const refFormatted = JSON.stringify(refParsed, null, 2);
    const compFormatted = JSON.stringify(compParsed, null, 2);
    const refLines = refFormatted.split('\n');
    const compLines = compFormatted.split('\n');

    // Criar mapa de diffs para lookup rápido
    const diffsByPath = new Map<string, DiffItem>();
    for (const item of currentResult.items) {
      // Só adiciona se o filtro estiver ativo
      if (activeFilters.has(item.type)) {
        diffsByPath.set(item.path, item);
      }
    }

    // Usar algoritmo LCS simplificado para alinhar linhas
    const syncedRef: { line: string; empty: boolean; diffType?: DiffType }[] = [];
    const syncedComp: { line: string; empty: boolean; diffType?: DiffType }[] = [];

    let ri = 0, ci = 0;
    
    while (ri < refLines.length || ci < compLines.length) {
      const refLine = ri < refLines.length ? refLines[ri] : null;
      const compLine = ci < compLines.length ? compLines[ci] : null;

      // Se ambas as linhas existem e são iguais, avança ambas
      if (refLine !== null && compLine !== null && refLine === compLine) {
        syncedRef.push({ line: refLine, empty: false });
        syncedComp.push({ line: compLine, empty: false });
        ri++;
        ci++;
        continue;
      }

      // Linhas diferentes - tentar encontrar correspondência
      if (refLine !== null && compLine !== null) {
        // Verificar se a linha do ref existe mais adiante no comp
        let foundInComp = -1;
        for (let k = ci + 1; k < Math.min(ci + 10, compLines.length); k++) {
          if (compLines[k] === refLine) {
            foundInComp = k;
            break;
          }
        }

        // Verificar se a linha do comp existe mais adiante no ref
        let foundInRef = -1;
        for (let k = ri + 1; k < Math.min(ri + 10, refLines.length); k++) {
          if (refLines[k] === compLine) {
            foundInRef = k;
            break;
          }
        }

        // Linha do comp está extra (não existe no ref)
        if (foundInRef === -1 && foundInComp >= 0) {
          // Linhas extras no comp até encontrar a correspondência
          while (ci < foundInComp) {
            syncedRef.push({ line: '', empty: true, diffType: 'extra' });
            syncedComp.push({ line: compLines[ci], empty: false, diffType: 'extra' });
            ci++;
          }
          continue;
        }

        // Linha do ref está faltando (não existe no comp)
        if (foundInComp === -1 && foundInRef >= 0) {
          // Linhas faltantes no ref até encontrar a correspondência
          while (ri < foundInRef) {
            syncedRef.push({ line: refLines[ri], empty: false, diffType: 'missing' });
            syncedComp.push({ line: '', empty: true, diffType: 'missing' });
            ri++;
          }
          continue;
        }

        // Ambas as linhas existem mas são diferentes - determinar tipo de diff
        let diffType: DiffType | undefined;
        
        // Verificar se as linhas têm a mesma chave
        const refKeyMatch = refLine.match(/^\s*"([^"]+)":/);
        const compKeyMatch = compLine.match(/^\s*"([^"]+)":/);
        
        if (refKeyMatch && compKeyMatch && refKeyMatch[1] === compKeyMatch[1]) {
          // Mesma chave, valor diferente
          const key = refKeyMatch[1];
          for (const [path, item] of diffsByPath) {
            if (path.endsWith(`.${key}`) || path.endsWith(`["${key}"]`)) {
              diffType = item.type;
              break;
            }
          }
        }

        syncedRef.push({ line: refLine, empty: false, diffType });
        syncedComp.push({ line: compLine, empty: false, diffType });
        ri++;
        ci++;
      } else if (refLine !== null) {
        // Linha extra no ref (faltando no comp)
        syncedRef.push({ line: refLine, empty: false, diffType: 'missing' });
        syncedComp.push({ line: '', empty: true, diffType: 'missing' });
        ri++;
      } else if (compLine !== null) {
        // Linha extra no comp
        syncedRef.push({ line: '', empty: true, diffType: 'extra' });
        syncedComp.push({ line: compLine, empty: false, diffType: 'extra' });
        ci++;
      } else {
        break;
      }
    }

    // Renderizar linhas
    function renderSyncedLines(lines: typeof syncedRef, side: 'ref' | 'comp'): string {
      let html = '';
      let lineNum = 0;

      for (const item of lines) {
        lineNum++;
        
        // Verifica se o filtro está ativo para este tipo de diff
        const shouldHideDiff = item.diffType && !activeFilters.has(item.diffType);
        
        if (item.empty) {
          // Se o filtro não está ativo, mostra linha vazia sem estilo de diff
          if (shouldHideDiff) {
            html += `<div class="djv-line djv-empty-line djv-hidden-diff">`;
            html += `<span class="djv-line-num">${lineNum}</span>`;
            html += `<span class="djv-line-indicator"> </span>`;
            html += `<span class="djv-line-content">&nbsp;</span>`;
            html += '</div>';
            continue;
          }
          
          html += `<div class="djv-line djv-empty-line">`;
          html += `<span class="djv-line-num">${lineNum}</span>`;
          html += `<span class="djv-line-indicator">~</span>`;
          html += `<span class="djv-line-content">&nbsp;</span>`;
          html += '</div>';
          continue;
        }

        const highlighted = syntaxHighlight(escapeHtml(item.line));
        let diffClass = '';
        let indicator = ' ';

        // Se o filtro não está ativo, não aplica o highlight
        if (item.diffType && !shouldHideDiff) {
          if (item.diffType === 'extra' && side === 'comp') {
            diffClass = 'djv-added';
            indicator = '+';
          } else if (item.diffType === 'missing' && side === 'ref') {
            diffClass = 'djv-removed';
            indicator = '−';
          } else if (item.diffType === 'type-wrong') {
            diffClass = 'djv-type-changed';
            indicator = '⚡';
          } else if (item.diffType === 'value-diff') {
            diffClass = 'djv-value-changed';
            indicator = '≠';
          }
        }

        html += `<div class="djv-line ${diffClass}">`;
        html += `<span class="djv-line-num">${lineNum}</span>`;
        html += `<span class="djv-line-indicator">${indicator}</span>`;
        html += `<span class="djv-line-content">${highlighted}</span>`;
        html += '</div>';
      }

      return html;
    }

    const refHtml = renderSyncedLines(syncedRef, 'ref');
    const compHtml = renderSyncedLines(syncedComp, 'comp');

    diffRefLines.innerHTML = refHtml;
    diffCompLines.innerHTML = compHtml;
  }

  function renderUnified() {
    if (!currentResult) return;
    unifiedContent.innerHTML = renderUnifiedView(currentResult.items);
  }

  function renderReport() {
    if (!currentResult) return;
    reportContent.innerHTML = renderReportView(currentResult.items);
  }

  // ========== SCROLL SYNC ==========
  let syncingScroll = false;

  function setupScrollSync() {
    if (!diffRefScroll || !diffCompScroll) return;

    diffRefScroll.addEventListener('scroll', () => {
      if (syncingScroll) return;
      syncingScroll = true;
      diffCompScroll.scrollTop = diffRefScroll.scrollTop;
      diffCompScroll.scrollLeft = diffRefScroll.scrollLeft;
      requestAnimationFrame(() => { syncingScroll = false; });
    });

    diffCompScroll.addEventListener('scroll', () => {
      if (syncingScroll) return;
      syncingScroll = true;
      diffRefScroll.scrollTop = diffCompScroll.scrollTop;
      diffRefScroll.scrollLeft = diffCompScroll.scrollLeft;
      requestAnimationFrame(() => { syncingScroll = false; });
    });
  }

  // ========== VIEW BUTTONS ==========
  function switchView(viewName: string) {
    viewBtns.forEach(btn => {
      const isActive = btn.getAttribute('data-view') === viewName;
      btn.classList.toggle('jd-view-btn-active', isActive);
    });

    viewSideBySide.classList.toggle('jd-view-active', viewName === 'side-by-side');
    viewUnified.classList.toggle('jd-view-active', viewName === 'unified');
    viewReport.classList.toggle('jd-view-active', viewName === 'report');
  }

  // ========== DEBOUNCED COMPARE ==========
  function scheduleCompare() {
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(compare, 400);
  }

  // ========== EVENT LISTENERS ==========
  // Auto-compare on input
  jsonRef.addEventListener('input', scheduleCompare);
  jsonComp.addEventListener('input', scheduleCompare);

  swapBtn.addEventListener('click', () => {
    const temp = jsonRef.value;
    jsonRef.value = jsonComp.value;
    jsonComp.value = temp;
    compare();
  });

