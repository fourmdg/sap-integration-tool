          </svg> Sair`
        : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
          </svg> Tela Cheia`;
    }
    
    document.body.style.overflow = isFullscreen ? 'hidden' : '';
  }

  fullscreenBtn?.addEventListener('click', toggleFullscreen);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isFullscreen) {
      toggleFullscreen();
    }
  });

  // ========== RESIZE HANDLE ==========
  const resizeHandle = document.getElementById('resizeHandle') as HTMLDivElement;
  const inputSection = document.getElementById('inputSection') as HTMLDivElement;
  let isResizing = false;
  let startY = 0;
  let startHeight = 0;

  resizeHandle?.addEventListener('mousedown', (e) => {
    isResizing = true;
    startY = e.clientY;
    startHeight = inputSection.offsetHeight;
    document.body.style.cursor = 'ns-resize';
    document.body.style.userSelect = 'none';
  });

  document.addEventListener('mousemove', (e) => {
    if (!isResizing) return;
    const delta = e.clientY - startY;
    const newHeight = Math.max(150, startHeight + delta);
    inputSection.style.height = `${newHeight}px`;
    
    const textareas = inputSection.querySelectorAll('.jd-textarea') as NodeListOf<HTMLTextAreaElement>;
    textareas.forEach(ta => {
      ta.style.height = `${newHeight - 50}px`;
    });
  });

  document.addEventListener('mouseup', () => {
    if (isResizing) {
      isResizing = false;
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
    }
  });

  // ========== INIT ==========
  loadOptions();
  setupScrollSync();
</script>

<style is:global>
  /* ========== CONTAINER ========== */
  .jd-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  /* ========== OPTIONS BAR ========== */
  .jd-options-bar {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: 10px var(--spacing-md);
