---
/**
 * JSON Field Validator - Valida campos contra definições de IDocs SAP
 * Detecta automaticamente os IDocs presentes no JSON
 * Usa dados centralizados do registro de IDocs
 */
import ToolLayout from '@features/tools/layouts/ToolLayout.astro';
import { ALL_IDOCS, createSegmentMap } from '@idocs/data';

// Serializar segmentos para client-side (dinâmico)
const idocSegments = Object.fromEntries(
  ALL_IDOCS.map((idoc) => [idoc.code, createSegmentMap(idoc)])
);

// Mapa de código do IDOC para título/info
const idocInfo = Object.fromEntries(
  ALL_IDOCS.map((idoc) => [idoc.code, { title: idoc.title, icon: idoc.icon }])
);
---

<ToolLayout
  title="Validador de Payload IDOC"
  description="Valide payloads JSON contra segmentos e campos de IDocs SAP"
  icon="📋"
>
  <div class="validator-content">
    <div class="input-section">
      <label class="field-label" for="jsonInput">JSON de Entrada</label>
      <textarea
        id="jsonInput"
        class="code-textarea"
        placeholder='Cole seu JSON aqui. O validador detecta automaticamente os IDocs presentes (ex: MATMAS05, DEBMAS07, ADRMAS03...)'
        rows="12"
      ></textarea>
    </div>

    <div id="resultsSection" class="results-section">
      <div class="results-header">
        <h3 class="results-title">Relatório de Validação</h3>
        <span id="resultsSummary" class="results-summary"></span>
      </div>

      <div id="resultsList" class="results-list"></div>
    </div>
  </div>
</ToolLayout>

<script is:inline define:vars={{ idocSegments, idocInfo }}>
  // Dados dos IDocs disponíveis no client-side
  window.IDOC_SEGMENTS = idocSegments;
  window.IDOC_INFO = idocInfo;
</script>

<style>
  .validator-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .field-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .input-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .code-textarea {
    width: 100%;
    padding: var(--spacing-md);
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 0.85rem;
    line-height: 1.5;
    background: var(--code-bg);
    color: #e2e8f0;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    resize: vertical;
  }

  .code-textarea:focus {
    outline: none;
    border-color: var(--brand-blue);
  }

  .results-section {
    display: none;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
  }

  .results-section.show {
    display: block;
  }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--meta-bg);
    border-bottom: 1px solid var(--border-color);
  }

  .results-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--heading-color);
  }

  .results-summary {
    font-size: 0.85rem;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .results-summary.success {
    background: var(--success-bg);
    color: var(--success-text);
  }

  .results-summary.warning {
    background: var(--warning-bg);
    color: var(--warning-text);
  }

  .results-summary.error {
    background: var(--danger-bg);
    color: var(--danger-text);
  }

  .results-list {
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  :global(.idoc-group) {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
  }

  :global(.idoc-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md);
    background: linear-gradient(135deg, var(--brand-blue) 0%, #6366f1 100%);
    color: white;
    font-weight: 700;
    font-size: 1rem;
  }

  :global(.idoc-content) {
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  :global(.collapsible) {
    margin-bottom: var(--spacing-md);
    border-radius: 8px;
    overflow: hidden;
  }

  :global(.collapsible summary) {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  :global(.collapsible summary::-webkit-details-marker) {
    display: none;
  }

  :global(.collapsible summary::before) {
    content: '▶';
    font-size: 0.7rem;
    transition: transform 0.2s;
  }

  :global(.collapsible[open] summary::before) {
    transform: rotate(90deg);
  }

  :global(.collapsible-content) {
    padding: var(--spacing-sm) var(--spacing-md);
    padding-top: 0;
  }

  :global(.collapsible.error) {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  :global(.collapsible.error summary) {
    color: var(--danger-text);
  }

  :global(.collapsible.warning) {
    background: var(--warning-bg);
    border: 1px solid var(--warning-border);
  }

  :global(.collapsible.warning summary) {
    color: var(--warning-text);
  }

  :global(.missing-list) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  :global(.missing-tag) {
    padding: 4px 8px;
    background: rgba(0,0,0,0.1);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.8rem;
  }

  :global(.segment-group) {
    background: var(--meta-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
  }

  :global(.segment-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--card-bg);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--heading-color);
    cursor: pointer;
    border-bottom: 1px solid var(--border-color);
  }

  :global(.segment-header:hover) {
    background: var(--border-color);
  }

  :global(.segment-badges) {
    display: flex;
    gap: 6px;
  }

  :global(.segment-badge) {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 600;
  }

  :global(.segment-badge.ok) {
    background: var(--success-bg);
    color: var(--success-text);
  }

  :global(.segment-badge.warn) {
    background: var(--warning-bg);
    color: var(--warning-text);
  }

  :global(.segment-badge.err) {
    background: var(--danger-bg);
    color: var(--danger-text);
  }

  :global(.segment-badge.missing) {
    background: rgba(100, 116, 139, 0.2);
    color: var(--text-muted);
  }

  :global(.segment-fields) {
    padding: var(--spacing-sm);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  :global(.field-result) {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: 6px var(--spacing-sm);
    border-radius: 4px;
    font-size: 0.85rem;
  }

  :global(.field-result.pass) {
    background: rgba(34, 197, 94, 0.1);
  }

  :global(.field-result.warn) {
    background: rgba(234, 179, 8, 0.1);
  }

  :global(.field-result.fail) {
    background: rgba(239, 68, 68, 0.1);
  }

  :global(.field-result.missing) {
    background: rgba(100, 116, 139, 0.1);
  }

  :global(.field-name) {
    font-weight: 600;
    min-width: 150px;
    font-family: monospace;
  }

  :global(.field-status) {
    flex-shrink: 0;
  }

  :global(.field-message) {
    flex: 1;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

</style>

<script>
  declare global {
    interface Window {
      IDOC_SEGMENTS: Record<string, Record<string, { description: string; fields: Array<{ name: string; description: string; type: string }> }>>;
      IDOC_INFO: Record<string, { title: string; icon: string }>;
    }
  }

  interface FieldValidation {
    name: string;
    status: 'pass' | 'warn' | 'fail' | 'missing';
    message: string;
    expected?: string;
  }

  interface SegmentValidation {
    segment: string;
    description: string;
    found: boolean;
    fields: FieldValidation[];
    missingFields: string[];
    unknownFields: string[];
  }

  interface IdocValidation {
    idocCode: string;
    idocTitle: string;
    idocIcon: string;
    segments: SegmentValidation[];
    missingSegments: string[];
    unknownStructures: string[];
  }

  const jsonInput = document.getElementById('jsonInput') as HTMLTextAreaElement;
  const resultsSection = document.getElementById('resultsSection') as HTMLDivElement;
  const resultsList = document.getElementById('resultsList') as HTMLDivElement;
  const resultsSummary = document.getElementById('resultsSummary') as HTMLSpanElement;

  // Parse type string like "CHAR(18)" or "NUMC(10)"
  function parseType(typeStr: string): { baseType: string; length: number | null } {
    const match = typeStr.match(/^(\w+)\((\d+)\)$/);
    if (match) {
      return { baseType: match[1], length: parseInt(match[2]) };
    }
    return { baseType: typeStr, length: null };
  }

  // Validate a field value against its type definition
  function validateField(value: any, typeStr: string): { status: 'pass' | 'warn' | 'fail'; message: string } {
    if (value === undefined || value === null) {
      return { status: 'pass', message: 'Campo vazio (opcional)' };
    }

    const strValue = String(value);
    const { baseType, length } = parseType(typeStr);

    // Check length
    if (length !== null && strValue.length > length) {
      return {
        status: 'fail',
        message: `Excede tamanho máximo: ${strValue.length}/${length} chars`
      };
    }

    // Validate by type
    switch (baseType.toUpperCase()) {
      case 'CHAR':
        return { status: 'pass', message: `OK (${strValue.length}/${length || '?'} chars)` };

      case 'NUMC':
        if (!/^\d*$/.test(strValue)) {
          return { status: 'fail', message: 'Deve conter apenas dígitos (NUMC)' };
        }
        return { status: 'pass', message: `OK (${strValue.length}/${length || '?'} digits)` };

      case 'DATS':
        if (strValue && !/^\d{8}$/.test(strValue)) {
          return { status: 'warn', message: 'Formato de data esperado: YYYYMMDD' };
        }
        return { status: 'pass', message: 'OK (YYYYMMDD)' };

      case 'TIMS':
        if (strValue && !/^\d{6}$/.test(strValue)) {
          return { status: 'warn', message: 'Formato de hora esperado: HHMMSS' };
        }
        return { status: 'pass', message: 'OK (HHMMSS)' };

      case 'DEC':
      case 'CURR':
      case 'QUAN':
        if (strValue && !/^-?\d*\.?\d+$/.test(strValue)) {
          return { status: 'fail', message: 'Deve ser valor numérico decimal' };
        }
        return { status: 'pass', message: 'OK (decimal)' };

      case 'UNIT':
      case 'CUKY':
        return { status: 'pass', message: `OK (${baseType})` };

      case 'LANG':
        if (length && strValue.length > length) {
          return { status: 'fail', message: `Código de idioma muito longo` };
        }
        return { status: 'pass', message: 'OK (idioma)' };

      default:
        return { status: 'pass', message: `OK (${typeStr})` };
    }
  }

  // Detect IDOCs in the JSON payload (only at root level or first level)
  function detectIdocs(json: any): string[] {
    const knownIdocs = Object.keys(window.IDOC_SEGMENTS);
    const found: string[] = [];

    if (typeof json !== 'object' || json === null) return found;

    // Check root level keys
    for (const key of Object.keys(json)) {
      if (knownIdocs.includes(key) && !found.includes(key)) {
        found.push(key);
      }
    }

    return found;
  }

  // Get the content under an IDOC key
  function getIdocContent(json: any, idocCode: string): any {
    function search(obj: any): any {
      if (typeof obj !== 'object' || obj === null) return null;

      for (const [key, value] of Object.entries(obj)) {
        if (key === idocCode) {
          return value;
        }
        const result = search(value);
        if (result) return result;
      }
      return null;
    }
    return search(json);
  }

  // Recursively find all keys in an object (for detecting structures)
  function getAllKeys(obj: any, parentKey: string = ''): Set<string> {
    const keys = new Set<string>();

    if (typeof obj !== 'object' || obj === null) return keys;

    if (Array.isArray(obj)) {
      obj.forEach(item => {
        getAllKeys(item, parentKey).forEach(k => keys.add(k));
      });
      return keys;
    }

    for (const [key, value] of Object.entries(obj)) {
      keys.add(key);
      // Also get nested keys
      getAllKeys(value, key).forEach(k => keys.add(k));
    }

    return keys;
  }

  // Find segment instances in JSON content
  function findSegmentInstances(content: any, segmentName: string): any[] {
    const instances: any[] = [];

    function search(obj: any) {
      if (typeof obj !== 'object' || obj === null) return;

      if (Array.isArray(obj)) {
        obj.forEach(item => search(item));
        return;
      }

      for (const [key, value] of Object.entries(obj)) {
        if (key === segmentName) {
          if (Array.isArray(value)) {
            instances.push(...value);
          } else if (typeof value === 'object' && value !== null) {
            instances.push(value);
          }
        }
        search(value);
      }
    }

    search(content);
    return instances;
  }

  // Validate a single IDOC
  function validateIdoc(json: any, idocCode: string): IdocValidation {
    const segments = window.IDOC_SEGMENTS[idocCode];
    const info = window.IDOC_INFO[idocCode] || { title: idocCode, icon: '📄' };
    const idocContent = getIdocContent(json, idocCode);

    const result: IdocValidation = {
      idocCode,
      idocTitle: info.title,
      idocIcon: info.icon,
      segments: [],
      missingSegments: [],
      unknownStructures: []
    };

    if (!segments || !idocContent) {
      return result;
    }

    // Get all keys present in the IDOC content
    const allKeysInContent = getAllKeys(idocContent);
    const knownSegments = new Set(Object.keys(segments));

    // Find unknown structures (keys that are not known segments and not primitive fields)
    for (const key of allKeysInContent) {
      if (!knownSegments.has(key)) {
        // Check if this key contains objects/arrays (suggesting it's a structure)
        const instances = findSegmentInstances(idocContent, key);
        if (instances.length > 0 && instances.some(i => typeof i === 'object')) {
          result.unknownStructures.push(key);
        }
      }
    }

    // Validate each defined segment
    for (const [segName, segDef] of Object.entries(segments)) {
      const instances = findSegmentInstances(idocContent, segName);

      if (instances.length === 0) {
        result.missingSegments.push(segName);
        continue;
      }

      // Validate each instance of this segment
      for (const instance of instances) {
        if (typeof instance !== 'object' || instance === null) continue;

        const fieldResults: FieldValidation[] = [];
        const missingFields: string[] = [];
        const unknownFields: string[] = [];
        const definedFieldNames = new Set(segDef.fields.map((f: any) => f.name));
        const providedFieldNames = new Set(Object.keys(instance));

        // Check each defined field
        for (const field of segDef.fields) {
          const value = instance[field.name];
          if (value !== undefined) {
            const validation = validateField(value, field.type);
            fieldResults.push({
              name: field.name,
              status: validation.status,
              message: validation.message,
              expected: field.type
            });
          } else {
            missingFields.push(field.name);
          }
        }

        // Find unknown fields (not structures, just primitive values)
        for (const key of providedFieldNames) {
          if (!definedFieldNames.has(key)) {
            const value = instance[key];
            // Only count as unknown field if it's not an array/object (those are structures)
            if (!Array.isArray(value) && (typeof value !== 'object' || value === null)) {
              unknownFields.push(key);
            }
          }
        }

        result.segments.push({
          segment: segName,
          description: segDef.description,
          found: true,
          fields: fieldResults,
          missingFields,
          unknownFields
        });
      }
    }

    return result;
  }

  // Render all IDOC validations
  function renderResults(validations: IdocValidation[]) {
    let totalIdocs = validations.length;
    let totalErrors = 0;
    let totalWarnings = 0;

    validations.forEach(v => {
      // Estruturas não definidas = erro
      totalErrors += v.unknownStructures.length;
      // Estruturas ausentes = aviso
      totalWarnings += v.missingSegments.length;
      v.segments.forEach(s => {
        // Campos extras (não definidos) = erro
        totalErrors += s.unknownFields.length;
        // Campos ausentes = aviso
        totalWarnings += s.missingFields.length;
        s.fields.forEach(f => {
          if (f.status === 'fail') totalErrors++;
          else if (f.status === 'warn') totalWarnings++;
        });
      });
    });

    // Summary - padronizado
    if (totalErrors > 0) {
      resultsSummary.textContent = `${totalIdocs} IDocs | ${totalErrors} erros, ${totalWarnings} avisos`;
      resultsSummary.className = 'results-summary error';
    } else if (totalWarnings > 0) {
      resultsSummary.textContent = `${totalIdocs} IDocs | ${totalWarnings} avisos`;
      resultsSummary.className = 'results-summary warning';
    } else {
      resultsSummary.textContent = `${totalIdocs} IDocs validados com sucesso`;
      resultsSummary.className = 'results-summary success';
    }

    let html = '';

    for (const idocVal of validations) {
      // Contagem para o IDoc
      let idocErrors = idocVal.unknownStructures.length;
      let idocWarnings = idocVal.missingSegments.length;
      idocVal.segments.forEach(s => {
        idocErrors += s.unknownFields.length + s.fields.filter(f => f.status === 'fail').length;
        idocWarnings += s.missingFields.length + s.fields.filter(f => f.status === 'warn').length;
      });

      let idocBadge = '';
      if (idocErrors > 0) {
        idocBadge = `<span class="segment-badge err">${idocErrors} erros</span>`;
      } else if (idocWarnings > 0) {
        idocBadge = `<span class="segment-badge warn">${idocWarnings} avisos</span>`;
      } else {
        idocBadge = `<span class="segment-badge ok">OK</span>`;
      }

      html += `<div class="idoc-group">`;
      html += `<div class="idoc-header">
        <span>${idocVal.idocIcon} ${idocVal.idocCode}</span>
        <div style="display: flex; align-items: center; gap: 12px;">
          ${idocBadge}
          <span style="font-weight: 400; font-size: 0.85rem; opacity: 0.8;">${idocVal.idocTitle}</span>
        </div>
      </div>`;
      html += `<div class="idoc-content">`;

      // Estruturas não definidas (ERRO) - aberto por padrão
      if (idocVal.unknownStructures.length > 0) {
        html += `
          <details class="collapsible error" open>
            <summary>❌ Estruturas não definidas (${idocVal.unknownStructures.length})</summary>
            <div class="collapsible-content">
              <div class="missing-list">
                ${idocVal.unknownStructures.map(s => `<span class="missing-tag">${s}</span>`).join('')}
              </div>
            </div>
          </details>
        `;
      }

      // Estruturas ausentes (AVISO) - fechado por padrão
      if (idocVal.missingSegments.length > 0) {
        html += `
          <details class="collapsible warning">
            <summary>⚠️ Estruturas ausentes (${idocVal.missingSegments.length})</summary>
            <div class="collapsible-content">
              <div class="missing-list">
                ${idocVal.missingSegments.map(s => `<span class="missing-tag">${s}</span>`).join('')}
              </div>
            </div>
          </details>
        `;
      }

      // Segmentos encontrados
      for (const seg of idocVal.segments) {
        const errorCount = seg.fields.filter(f => f.status === 'fail').length + seg.unknownFields.length;
        const warnCount = seg.fields.filter(f => f.status === 'warn').length + seg.missingFields.length;
        const okCount = seg.fields.filter(f => f.status === 'pass').length;

        let badge = '';
        if (errorCount > 0 && warnCount > 0) {
          badge = `<span class="segment-badge err">${errorCount} erros</span><span class="segment-badge warn">${warnCount} avisos</span>`;
        } else if (errorCount > 0) {
          badge = `<span class="segment-badge err">${errorCount} erros</span>`;
        } else if (warnCount > 0) {
          badge = `<span class="segment-badge warn">${warnCount} avisos</span>`;
        } else if (okCount > 0) {
          badge = `<span class="segment-badge ok">${okCount} OK</span>`;
        }

        html += `
          <div class="segment-group">
            <div class="segment-header">
              <span>📦 ${seg.segment}</span>
              <div class="segment-badges">${badge}</div>
            </div>
            <div class="segment-fields">
        `;

        // Campos extras não definidos (ERRO) - aberto por padrão
        if (seg.unknownFields.length > 0) {
          html += `
            <details class="collapsible error" style="margin: 0 0 var(--spacing-sm) 0;" open>
              <summary>❌ Campos extras (${seg.unknownFields.length})</summary>
              <div class="collapsible-content">
                <div class="missing-list">
                  ${seg.unknownFields.map(f => `<span class="missing-tag">${f}</span>`).join('')}
                </div>
              </div>
            </details>
          `;
        }

        // Campos ausentes (AVISO) - fechado por padrão
        if (seg.missingFields.length > 0) {
          html += `
            <details class="collapsible warning" style="margin: 0 0 var(--spacing-sm) 0;">
              <summary>⚠️ Campos ausentes (${seg.missingFields.length})</summary>
              <div class="collapsible-content">
                <div class="missing-list">
                  ${seg.missingFields.map(f => `<span class="missing-tag">${f}</span>`).join('')}
                </div>
              </div>
            </details>
          `;
        }

        // Campos validados
        if (seg.fields.length > 0) {
          for (const f of seg.fields) {
            const icon = f.status === 'pass' ? '✅' : f.status === 'warn' ? '⚠️' : '❌';
            html += `
              <div class="field-result ${f.status}">
                <span class="field-status">${icon}</span>
                <span class="field-name">${f.name}</span>
                <span class="field-message">${f.message}</span>
              </div>
            `;
          }
        }

        html += `</div></div>`;
      }

      html += `</div></div>`;
    }

    if (validations.length === 0) {
      html = `
        <details class="collapsible warning" open>
          <summary>⚠️ Nenhum IDoc detectado no payload</summary>
          <div class="collapsible-content">
            <p style="margin: 0; font-size: 0.85rem;">
              Verifique se o JSON contém pelo menos um IDoc válido no formato esperado.<br>
              IDocs suportados: ${Object.keys(window.IDOC_SEGMENTS).join(', ')}
            </p>
          </div>
        </details>
      `;
    }

    resultsList.innerHTML = html;
    resultsSection.classList.add('show');
  }

  // Debounce function
  function debounce(fn: Function, delay: number) {
    let timer: number;
    return (...args: any[]) => {
      clearTimeout(timer);
      timer = window.setTimeout(() => fn(...args), delay);
    };
  }

  // Validate function
  function validate() {
    const value = jsonInput.value.trim();

    if (!value) {
      resultsSection.classList.remove('show');
      return;
    }

    let json: any;

    try {
      json = JSON.parse(value);
    } catch (e: any) {
      resultsSummary.textContent = '❌ JSON inválido';
      resultsSummary.className = 'results-summary error';
      resultsList.innerHTML = `
        <div class="field-result fail">
          <span class="field-status">❌</span>
          <span class="field-message">Erro de parse: ${e.message}</span>
        </div>
      `;
      resultsSection.classList.add('show');
      return;
    }

    // Detect all IDOCs in the payload
    const detectedIdocs = detectIdocs(json);

    // Validate each detected IDOC
    const validations = detectedIdocs.map(idocCode => validateIdoc(json, idocCode));

    renderResults(validations);
  }

  // Auto-validate on input with debounce
  const debouncedValidate = debounce(validate, 300);
  jsonInput.addEventListener('input', debouncedValidate);

  // Immediate validate on paste
  jsonInput.addEventListener('paste', () => {
    setTimeout(validate, 10);
  });
</script>
