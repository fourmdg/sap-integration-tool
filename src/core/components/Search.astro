---
/**
 * Search.astro - Componente de busca global
 * Índice gerado em build-time usando fonte centralizada
 */
import { FULL_SEARCH_INDEX } from '@idocs/data';

// Usar índice centralizado
const searchIndex = FULL_SEARCH_INDEX;
---

<div class="search-wrapper">
  <input
    type="text"
    class="search-input"
    id="globalSearch"
    placeholder="Buscar..."
    autocomplete="off"
  />
  <div class="search-results" id="searchResults"></div>
</div>

<style>
  .search-wrapper {
    position: relative;
  }

  .search-input {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    padding: 8px 14px;
    border-radius: 8px;
    width: 240px;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .search-input::placeholder {
    color: rgba(255,255,255,0.5);
  }

  .search-input:focus {
    background: rgba(255,255,255,0.15);
    border-color: var(--brand-blue);
    width: 280px;
    outline: none;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 380px;
    max-height: 450px;
    overflow-y: auto;
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    display: none;
    z-index: 9999;
  }

  :global([data-theme="dark"]) .search-results {
    background: #1e293b;
  }

  .search-results.open {
    display: block;
  }

  .search-results:empty {
    display: none;
  }

  :global(.search-result-item) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    text-decoration: none;
    color: #334155;
    border-bottom: 1px solid #f1f5f9;
    transition: background 0.15s;
  }

  :global([data-theme="dark"] .search-result-item) {
    color: #e2e8f0;
    border-bottom-color: #334155;
  }

  :global(.search-result-item:hover) {
    background: #f8fafc;
  }

  :global([data-theme="dark"] .search-result-item:hover) {
    background: rgba(255,255,255,0.05);
  }

  :global(.search-result-item:last-child) {
    border-bottom: none;
  }

  :global(.search-result-icon) {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  :global(.search-result-content) {
    flex: 1;
    min-width: 0;
  }

  :global(.search-result-title) {
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 2px;
  }

  :global(.search-result-desc) {
    font-size: 0.75rem;
    color: #64748b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.search-result-type) {
    font-size: 0.65rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: #f1f5f9;
    color: #64748b;
    text-transform: uppercase;
    font-weight: 600;
  }

  :global(.search-no-results) {
    padding: 20px;
    text-align: center;
    color: #64748b;
    font-size: 0.85rem;
  }

  :global(.search-view-all) {
    display: block;
    padding: 12px 16px;
    text-align: center;
    color: var(--brand-blue);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    border-top: 1px solid var(--border-color);
    transition: background 0.15s;
  }

  :global(.search-view-all:hover) {
    background: var(--meta-bg);
  }

  @media (max-width: 900px) {
    .search-input {
      width: 100%;
    }

    .search-input:focus {
      width: 100%;
    }

    .search-results {
      width: 100%;
      min-width: 280px;
    }
  }
</style>

<script is:inline define:vars={{ searchIndex }}>
  window.SEARCH_INDEX = searchIndex;
</script>

<script>
  interface SearchItem {
    title: string;
    url: string;
    type: 'tool' | 'idoc' | 'doc' | 'field' | 'segment';
    description: string;
    segment?: string;
  }

  declare global {
    interface Window {
      SEARCH_INDEX: SearchItem[];
    }
  }

  function search(query: string): SearchItem[] {
    if (!query.trim()) return [];

    const q = query.toLowerCase();
    return window.SEARCH_INDEX.filter(item =>
      item.title.toLowerCase().includes(q) ||
      item.description?.toLowerCase().includes(q) ||
      item.segment?.toLowerCase().includes(q)
    ).slice(0, 10);
  }

  function renderResults(results: SearchItem[], query: string) {
    const container = document.getElementById('searchResults');
    if (!container) return;

    if (results.length === 0) {
      container.innerHTML = '<div class="search-no-results">Nenhum resultado encontrado</div>';
      container.classList.add('open');
      return;
    }

    const typeIcons: Record<string, string> = {
      idoc: '📦',
      doc: '📚',
      tool: '🛠️',
      segment: '📋',
      field: '🔤'
    };

    const resultsHtml = results.slice(0, 5).map(r => `
      <a href="${r.url}" class="search-result-item">
        <span class="search-result-icon">${typeIcons[r.type] || '📄'}</span>
        <div class="search-result-content">
          <div class="search-result-title">${r.title}</div>
          <div class="search-result-desc">${r.description || ''}</div>
        </div>
        <span class="search-result-type">${r.type}</span>
      </a>
    `).join('');

    const viewAllHtml = `
      <a href="/search?q=${encodeURIComponent(query)}" class="search-view-all">
        Ver todos os resultados →
      </a>
    `;

    container.innerHTML = resultsHtml + viewAllHtml;
    container.classList.add('open');
  }

  const input = document.getElementById('globalSearch') as HTMLInputElement;
  const resultsContainer = document.getElementById('searchResults');

  input?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value;
    if (query.length >= 2) {
      const results = search(query);
      renderResults(results, query);
    } else {
      resultsContainer?.classList.remove('open');
    }
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.search-wrapper')) {
      resultsContainer?.classList.remove('open');
    }
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      resultsContainer?.classList.remove('open');
      input.blur();
    } else if (e.key === 'Enter' && input.value.trim()) {
      window.location.href = `/search?q=${encodeURIComponent(input.value.trim())}`;
    }
  });
</script>
